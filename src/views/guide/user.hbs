<!-- HERO -->
<section class="hero-section">
  <div class="container">
    <div class="row align-items-center gy-4">
      <div class="col-lg-7">
        <span class="badge bg-white text-primary fw-semibold mb-3">How-to guide</span>
        <h1 class="display-6 fw-bold mb-3">How to create, track, and view your machine request</h1>
        <p class="lead opacity-75 mb-0">
          Follow three simple steps: fill in the request form, monitor the status in the request list, and view your machine once the request is approved.
        </p>
      </div>
      <div class="col-lg-5">
        <div class="card border-0 rounded-4 shadow-sm p-4">
          <h6 class="fw-bold text-dark mb-3">Flow overview</h6>
          <div class="d-flex flex-column gap-3">
            <div class="overview-item">
              <span class="overview-dot mt-1"></span>
              <span class="text-muted small">Complete the <strong class="text-dark">New Request</strong> form and submit it.</span>
            </div>
            <div class="overview-item">
              <span class="overview-dot mt-1"></span>
              <span class="text-muted small">Open the <strong class="text-dark">Request</strong> page to monitor status.</span>
            </div>
            <div class="overview-item">
              <span class="overview-dot mt-1"></span>
              <span class="text-muted small">When approved, view your machine in <strong class="text-dark">Machines</strong>.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STEPS -->
<main class="container py-5" id="main-content">

  <!-- STEP 1 -->
  <div class="card step-card mb-2">
    <div class="card-body">
      <div class="d-flex align-items-center gap-3 mb-4">
        <div class="step-number">1</div>
        <div>
          <h2 class="h4 fw-bold mb-0">Fill in the request form</h2>
          <p class="text-muted mb-0 mt-1">Start on the <strong>New Request</strong> page and complete all required fields.</p>
        </div>
      </div>
      <div class="row gy-4 align-items-start">
        <div class="col-lg-7">
          <ol class="d-flex flex-column gap-2 mb-4">
            <li>Select the <strong>Approver</strong> from the drop-down menu.</li>
            <li>Optionally add a note in the <strong>Observation</strong> field.</li>
            <li>In the <strong>Machines</strong> section, enter the <strong>Hostname</strong>.</li>
            <li>Choose the required <strong>Template</strong> from the drop-down.</li>
            <li>Click <strong>+ Add machines</strong> if you need more than one machine.</li>
            <li>Click <strong>Send Request</strong> to submit.</li>
          </ol>
          <div class="tip-box">
            <i class="bi bi-lightbulb-fill me-2"></i>
            Double-check the hostname and template before submitting so the approver receives correct information.
          </div>
        </div>
        <div class="col-lg-5">
          <figure class="screenshot m-0">
            <img src="/img/request_form.png" class="img-fluid" alt="New Request form with approver, observation, hostname, template and Send Request button" loading="lazy">
            <figcaption><i class="bi bi-image me-1"></i>New Request form</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>

  <div class="step-connector my-1"></div>

  <!-- STEP 2 -->
  <div class="card step-card mb-2">
    <div class="card-body">
      <div class="d-flex align-items-center gap-3 mb-4">
        <div class="step-number">2</div>
        <div>
          <h2 class="h4 fw-bold mb-0">Check your requests</h2>
          <p class="text-muted mb-0 mt-1">Open the <strong>Request</strong> page to see all your submitted requests and their current status.</p>
        </div>
      </div>
      <div class="row gy-4 align-items-start">
        <div class="col-lg-7">
          <ol class="d-flex flex-column gap-2 mb-4">
            <li>Navigate to the <strong>Request</strong> page.</li>
            <li>Find your request by number, approver, or creation date.</li>
            <li>Read the <strong>Status</strong> column to check the current state.</li>
            <li>If still pending, wait for the approver to review your request.</li>
          </ol>
          <div class="tip-box mb-3">
            <p class="fw-semibold mb-2"><i class="bi bi-info-circle-fill me-2"></i>Possible statuses:</p>
            <div class="d-flex gap-2 flex-wrap">
              <span class="badge rounded-pill px-3 py-2" style="background:#fff3cd;color:#7d5a00;border:1px solid #ffe69c;">
                <i class="bi bi-clock me-1"></i>Pending
              </span>
              <span class="badge rounded-pill px-3 py-2" style="background:#d1e7dd;color:#0a5c36;border:1px solid #a3cfbb;">
                <i class="bi bi-check-circle me-1"></i>Approved
              </span>
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <figure class="screenshot m-0">
            <img src="/img/request_list.png" class="img-fluid" alt="Request list showing a pending request with approver name, status, number of machines, and creation date" loading="lazy">
            <figcaption><i class="bi bi-image me-1"></i>Request list with a pending request</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>

  <div class="step-connector my-1"></div>

  <!-- STEP 3 -->
  <div class="card step-card mb-5">
    <div class="card-body">
      <div class="d-flex align-items-center gap-3 mb-4">
        <div class="step-number">3</div>
        <div>
          <h2 class="h4 fw-bold mb-0">View the machine after approval</h2>
          <p class="text-muted mb-0 mt-1">Once approved, go to the <strong>Machines</strong> page to see the machine and its connection details.</p>
        </div>
      </div>
      <div class="row gy-4 align-items-start">
        <div class="col-lg-7">
          <ol class="d-flex flex-column gap-2 mb-4">
            <li>Wait until your request shows as <strong>Approved</strong> in the request list.</li>
            <li>Open the <strong>Machines</strong> page.</li>
            <li>Locate your machine in the table.</li>
            <li>Review the details: <strong>VMID</strong>, <strong>Type</strong>, <strong>Status</strong>, <strong>IP address</strong>, <strong>Hostname</strong>, and <strong>Template</strong>.</li>
            <li>Use the action buttons to manage or inspect the machine if needed.</li>
          </ol>
          <div class="tip-box">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            If the machine is not visible yet, the request may still be under review or provisioning may not be complete.
          </div>
        </div>
        <div class="col-lg-5">
          <figure class="screenshot m-0">
            <img src="/img/machines.png" class="img-fluid" alt="Machines page showing one running LXC machine with VMID, IP, hostname, template and action buttons" loading="lazy">
            <figcaption><i class="bi bi-image me-1"></i>Machine list after request approval</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER NOTE -->
  <div class="alert alert-light border rounded-4 p-4">
    <h6 class="fw-bold mb-2"><i class="bi bi-pin-angle-fill me-2 text-primary"></i>Remember</h6>
    <p class="mb-0 text-muted">
      Always start by creating a request, then monitor it in the request list. You can only view the machine in the <strong>Machines</strong> section after the request has been approved by the designated approver.
    </p>
  </div>